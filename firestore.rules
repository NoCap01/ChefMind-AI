rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isModerator() {
      return isAuthenticated() && 
             (isAdmin() || exists(/databases/$(database)/documents/moderators/$(request.auth.uid)));
    }
    
    function isGroupMember(groupId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/community/cookingGroups/$(groupId)).data.memberIds;
    }
    
    function isGroupAdmin(groupId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/community/cookingGroups/$(groupId)).data.adminIds;
    }
    
    function validateUserProfile(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'createdAt', 'lastUpdated']) &&
             data.id is string &&
             data.name is string &&
             data.email is string &&
             data.createdAt is timestamp &&
             data.lastUpdated is timestamp;
    }
    
    function validateRecipe(data) {
      return data.keys().hasAll(['id', 'title', 'ingredients', 'instructions', 'createdAt']) &&
             data.id is string &&
             data.title is string &&
             data.ingredients is list &&
             data.instructions is list &&
             data.createdAt is timestamp;
    }
    
    // Rate limiting helper
    function withinRateLimit(collection, limit) {
      return request.time > resource.data.lastAction + duration.value(1, 's') ||
             resource.data.actionCount < limit;
    }

    // Users collection - private user data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
      
      // User profile subcollections
      match /recipes/{recipeId} {
        allow read, write: if isOwner(userId);
        allow read: if resource.data.visibility == 'public' || 
                       resource.data.visibility == 'friendsOnly' && 
                       exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
      }
      
      match /collections/{collectionId} {
        allow read, write: if isOwner(userId);
        allow read: if resource.data.isPublic == true;
      }
      
      match /shoppingLists/{listId} {
        allow read, write: if isOwner(userId) || 
                             request.auth.uid in resource.data.sharedWithUserIds;
      }
      
      match /pantry/{itemId} {
        allow read, write: if isOwner(userId);
      }
      
      match /mealPlans/{planId} {
        allow read, write: if isOwner(userId) || 
                             request.auth.uid in resource.data.sharedWithUserIds;
      }
      
      match /nutritionLogs/{logId} {
        allow read, write: if isOwner(userId);
      }
      
      match /achievements/{achievementId} {
        allow read: if isOwner(userId) || resource.data.isPublic == true;
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /socialConnections/{connectionId} {
        allow read, write: if isOwner(userId) || 
                             request.auth.uid == resource.data.connectedUserId;
      }
      
      match /cookingSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
      
      match /challenges/{challengeId} {
        allow read, write: if isOwner(userId);
      }
      
      match /analytics {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin();
      }
    }

    // Community collection - public and shared content
    match /community/{document=**} {
      allow read: if isAuthenticated();
    }
    
    match /community/sharedRecipes/{recipeId} {
      allow create: if isAuthenticated() && 
                       validateRecipe(request.resource.data) &&
                       request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                       resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && 
                       (resource.data.authorId == request.auth.uid || isModerator());
    }
    
    match /community/cookingGroups/{groupId} {
      allow read: if resource.data.visibility == 'public' || 
                     isGroupMember(groupId);
      allow create: if isAuthenticated();
      allow update: if isGroupAdmin(groupId) || isAdmin();
      allow delete: if resource.data.creatorId == request.auth.uid || isAdmin();
      
      match /posts/{postId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update: if resource.data.authorId == request.auth.uid || isGroupAdmin(groupId);
        allow delete: if resource.data.authorId == request.auth.uid || isGroupAdmin(groupId);
      }
    }
    
    match /community/tutorials/{tutorialId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isModerator();
    }
    
    match /community/challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if resource.data.creatorId == request.auth.uid || isAdmin();
      allow delete: if resource.data.creatorId == request.auth.uid || isAdmin();
      
      match /submissions/{submissionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && 
                         request.resource.data.userId == request.auth.uid;
        allow update: if resource.data.userId == request.auth.uid;
        allow delete: if resource.data.userId == request.auth.uid || isAdmin();
      }
    }
    
    match /community/marketplace/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.resource.data.sellerId == request.auth.uid;
      allow update: if resource.data.sellerId == request.auth.uid;
      allow delete: if resource.data.sellerId == request.auth.uid || isAdmin();
    }

    // Comments and interactions
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.resource.data.authorId == request.auth.uid;
      allow update: if resource.data.authorId == request.auth.uid;
      allow delete: if resource.data.authorId == request.auth.uid || isModerator();
    }
    
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      allow update: if resource.data.userId == request.auth.uid;
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Admin and moderation
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side functions can modify
    }
    
    match /moderators/{moderatorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
    }

    // System collections
    match /systemConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only server-side functions can write
    }
    
    // Rate limiting collection
    match /rateLimits/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}